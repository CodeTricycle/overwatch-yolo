  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: #eef1f5;
}
QWidget#centralwidget {
    background: #eef1f5;
    color: #1f2937;
    font-family: "Microsoft YaHei";
}
QWidget#settingWidget,
QWidget#yoloSettingsWidget {
    background: #ffffff;
    border: 1px solid #d9dee7;
    border-radius: 8px;
}
QLabel#aimSettingsTitle,
QLabel#label_17 {
    color: #111827;
    font-size: 18px;
    font-weight: 700;
}
QLabel {
    color: #374151;
    background: transparent;
}
QLabel#modelFileLabel {
    background: #f8fafc;
    border: 1px solid #d1d7e0;
    border-radius: 4px;
    color: #334155;
    padding-left: 8px;
}
QComboBox,
QDoubleSpinBox {
    min-height: 26px;
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    color: #1f2937;
    padding-left: 7px;
    selection-background-color: #2563eb;
}
QDoubleSpinBox {
    max-width: 72px;
}
QComboBox:hover,
QDoubleSpinBox:hover {
    border-color: #94a3b8;
}
QComboBox::drop-down {
    width: 24px;
    border: 0;
}
QSlider::groove:horizontal {
    height: 4px;
    background: #dbe3ee;
    border-radius: 2px;
}
QSlider::handle:horizontal {
    width: 14px;
    height: 14px;
    margin: -5px 0;
    border-radius: 7px;
    background: #2563eb;
}
QSlider::sub-page:horizontal {
    background: #2563eb;
    border-radius: 2px;
}
QPushButton {
    min-height: 28px;
    border: 0;
    border-radius: 5px;
    background: #2563eb;
    color: #ffffff;
    font-weight: 600;
}
QPushButton:hover {
    background: #1d4ed8;
}
QPushButton#renameProfileButton {
    background: #475569;
}
QPushButton#renameProfileButton:hover {
    background: #334155;
}
QPushButton#deleteProfileButton {
    background: #dc2626;
}
QPushButton#deleteProfileButton:hover {
    background: #b91c1c;
}
QPushButton#chooseModelButton {
    max-width: 64px;
}
QPushButton#HotkeyPushButton {
    max-width: 112px;
}
QCheckBox {
    color: #1f2937;
    spacing: 8px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #94a3b8;
    border-radius: 4px;
    background: #ffffff;
}
QCheckBox::indicator:checked {
    background: #2563eb;
    border-color: #2563eb;
}
QWidget#statusDisplayWidget {
    background: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
}
QWidget#closeMessageWidget {
    background: #111827;
    border-radius: 8px;
}
QLabel#label_5 {
    color: #ffffff;
}
QLabel#statusDisplayLabel {
    color: #111827;
}</string>
